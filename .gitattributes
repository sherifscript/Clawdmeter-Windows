# Normalize line endings: let Git decide text vs. binary, checkout native.
* text=auto

# Keep Windows-oriented scripts as CRLF on checkout.
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Keep these LF regardless of platform.
*.py    text eol=lf
*.sh    text eol=lf

# Treat binary assets as binary (no EOL conversion, no diff noise).
*.png   binary
*.ico   binary
*.exe   binary
